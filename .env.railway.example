# Railway Deployment — Environment Variables
# Set these in Railway Dashboard → Variables
# Postgres credentials are auto-injected by the Railway Postgres plugin

APP_NAME=ETB Sklep
APP_ENV=production
APP_DEBUG=false
APP_KEY=base64:YOUR_GENERATED_KEY_HERE
APP_URL=https://YOUR_PROJECT.up.railway.app

APP_LOCALE=pl
APP_FALLBACK_LOCALE=pl
APP_FAKER_LOCALE=pl_PL

HASH_DRIVER=argon2id
BCRYPT_ROUNDS=12
PASSWORD_MIN_LENGTH=15
PASSWORD_MAX_LENGTH=128

LOG_CHANNEL=stack
LOG_LEVEL=warning

DB_CONNECTION=pgsql
# DB_HOST, DB_PORT, DB_DATABASE, DB_USERNAME, DB_PASSWORD — auto-injected by Railway Postgres plugin

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_SECURE_COOKIE=true

QUEUE_CONNECTION=database
CACHE_STORE=database
FILESYSTEM_DISK=local

MAIL_MAILER=smtp
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=587
MAIL_USERNAME=your_mailtrap_username
MAIL_PASSWORD=your_mailtrap_password
MAIL_FROM_ADDRESS="sklep@etb-basket.pl"
MAIL_FROM_NAME="${APP_NAME}"

# Przelewy24 sandbox — use sandbox credentials from your P24 panel
PRZELEWY24_MERCHANT_ID=
PRZELEWY24_POS_ID=
PRZELEWY24_CRC_KEY=
PRZELEWY24_API_KEY=
PRZELEWY24_BASE_URL=https://sandbox.przelewy24.pl
PRZELEWY24_REPORT_URL=https://YOUR_PROJECT.up.railway.app/payment/przelewy24/webhook

SHIPPING_PROVIDER=inpost

# Seller info for invoices
INVOICE_SELLER_NAME=ETB Sklep
INVOICE_SELLER_ADDRESS=ul. Przykładowa 1, 00-001 Warszawa
INVOICE_SELLER_NIP=1234567890
