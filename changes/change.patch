+        'opponent',
+        'match_date',
+        'location',
+        'result',
+    ];
+
+    /**
+     * @return array<string, string>
+     */
+    protected function casts(): array
+    {
+        return [
+            'match_date' => 'datetime',
+        ];
+    }
+}
